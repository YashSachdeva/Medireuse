# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medireuse?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d
REFRESH_EXPIRE_DAYS=30

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Cloudinary Configuration (Get these from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway (if using)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Service (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Admin Details
ADMIN_EMAIL=admin@medireuse.com
ADMIN_PASSWORD=your_admin_password
